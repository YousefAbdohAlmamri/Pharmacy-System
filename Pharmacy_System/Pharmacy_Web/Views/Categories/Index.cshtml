@model IEnumerable<Pharmacy_Web.Models.Category>

@{
    ViewData["Title"] = "Index";
}


<div>
    <h1 class="text-secondary">الفئات</h1>

    <p>
        <a asp-action="Create" class="btn btn-primary">إنشاء فئة</a>
    </p>
    <table class="table table-striped table-hover table-bordered" style="border-color:#364556;">
        <thead class="table-dark">
            <tr>
                <th class="text-bold text-light">
                    @Html.DisplayNameFor(model => model.Name)
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody class="table-secondary">
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.Name)
                    </td>
                    <td>
                        <a class="btn btn-sm btn-warning" asp-action="Edit" asp-controller="Categories" asp-route-id="@item.Id">Edit</a> |
                        <a class="btn btn-sm btn-info" asp-action="Details" asp-controller="Categories" asp-route-id="@item.Id">Details</a> |
                        <a class="btn btn-sm btn-danger" asp-action="Delete" asp-controller="Categories" asp-route-id="@item.Id">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>