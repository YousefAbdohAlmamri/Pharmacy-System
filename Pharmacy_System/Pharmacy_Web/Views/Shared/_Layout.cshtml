    .brand-link {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px 15px;
        text-decoration: none;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        transition: all 0.3s ease;
        position :relative;
    }

    .brand-link:hover {
        background-color: rgba(255, 255, 255, 0.05);
    }

        .brand-text {
            border-radius: 10px;
            width: 140px;
            height: 45px;
        }

            .brand-text::before {
                position: absolute;
                width: 15px;
                height: 45px;
                background-color: blue;
                top: 0;
                left: -20px;
            }

            .brand-text::after {
                position: absolute;
            }
        /* تنسيق عنوان SNIPER */
        .sniper-title {
            position: relative;
            display: inline-block;
            font-size: 1.6rem;
            font-weight: 700;
            /*color: transparent;*/
            background: linear-gradient(90deg, #00d2ff 0%, #3a7bd5 50%, #00d2ff 100%);
            background-size: 200% auto;
            top: 3px;
            /*-webkit-background-clip: text;
        background-clip: text;*/
            animation: shine 3s linear infinite;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .sniper-text {
            position: relative;
            z-index: 2;
            right: 6px;
            color: #374151;
            font-weight: bold;
            display: flex;
            justify-content: center;
            right: -1px;
        }
        /*
    .sniper-dot {
        color: #e94560;
        font-size: 2.2rem;
        vertical-align: top;
        animation: pulse 1.5s infinite;
    }
            */
    .sniper-shadow {
        position: absolute;
        bottom: -5px;
        left: 0;
        width: 100%;
        height: 10px;
        background: radial-gradient(ellipse at center,
                    rgba(0, 210, 255, 0.4) 0%,
                    rgba(0, 210, 255, 0) 70%);
        filter: blur(5px);
        transform: scaleX(0.9);
        opacity: 0.8;
        animation: shadowPulse 3s ease-in-out infinite;
    }

    /* تأثيرات الحركة */
    @@keyframes shine {
        to {
            background-position: 200% center;
        }
    }

    @@keyframes pulse {
        0% { transform: scale(1); opacity: 1; }
        50% { transform: scale(1.2); opacity: 0.8; }
        100% { transform: scale(1); opacity: 1; }
    }

    @@keyframes shadowPulse {
        0% { transform: scaleX(0.9); opacity: 0.8; }
        50% { transform: scaleX(1.1); opacity: 0.5; }
        100% { transform: scaleX(0.9); opacity: 0.8; }
    }

    /* تأثير عند التمرير */
    .brand-link:hover .sniper-title {
        animation: shine 1.5s linear infinite, bounce 0.5s ease;
    }

    @@keyframes bounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-5px); }
    }

        .footer_website {
            /*position: inherit;*/
            position: fixed;
            left: 0;
            bottom: 0;
            width: -webkit-fill-available;
            height:60px;
        }
    </style>

