    /* تنسيق البطاقات */
    .medicines-grid {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;

    }

        .medicine-card {
            /*background: white;*/
            border-radius: 20px;
            width: 185px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            transition: all 0.3s ease;
            height: 95%;
            display: flex;
            flex-direction: column;
            border-color: #83AACC;
            border-style: solid;
        }

    .medicine-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.15);
    }

    .medicine-image {
        position: relative;
        width: 136px;
        height: 160px;
        border-radius: 50%;
        margin: -40px auto 20px;
        border: 1px solid white;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        overflow: hidden;
        transition: all 0.3s ease;
    }

    .medicine-card:hover .medicine-image {
        transform: scale(1.05);
    }

    .medicine-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .image-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(52, 152, 219, 0.2);
        opacity: 0;
        transition: all 0.3s ease;
    }

    .medicine-card:hover .image-overlay {
        opacity: 1;
    }

    .medicine-content {
        padding: 0 20px 30px;
        text-align: center;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .medicine-title {
        font-size: 22px;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 15px;
    }

    .tag-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #3498db, #6c8bab);
        color: white;
        padding: 5px 20px;
        border-radius: 30px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(52, 152, 219, 0.3);
        margin-top: auto;
    }

    .tag-button:hover {
        background: linear-gradient(135deg, #2980b9, #5d91c6);
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(52, 152, 219, 0.4);
        color: white;
    }

    .tag-button i {
        margin-right: 8px;
        transition: all 0.3s ease;
    }

    .tag-button:hover i {
        transform: translateX(3px);
    }



        /*تصميم متجاوب*/
    @@media (max-width: 992px) {
        .medicine-card {
            max-width: 220px;
        }

        .medicine-image {
            width: 150px;
            height: 150px;
        }
    }

    @@media (max-width: 768px) {
        .animated-title {
            font-size: 2rem;
        }

        .medicines-grid {
            gap: 20px;
        }

        .medicine-card {
            max-width: 100%;
        }
