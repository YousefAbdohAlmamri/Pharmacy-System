@model IEnumerable<Pharmacy_Web.Models.Pharmacy>

@{
    ViewData["Title"] = "Index";
}


<div>
    <h1>الصيدليات</h1>

    <p>
        <a asp-action="Create" class="btn btn-primary">إضافة صيدلية</a>
    </p>
    <table class="table table-striped table-hover table-bordered" style="border-color:#364556;">
        <thead class="navbar-dark">
            <tr>
                <th class="text-bold text-light">
                    الاسم
                </th>
                <th class="text-bold text-light">
                    الوصف
                </th>
                <th class="text-bold text-light">
                    الصورة
                </th>
                <th class="text-bold text-light">
                    الموقع
                </th>
                <th class="text-bold text-light">
                    التلفون
                </th>
                <th class="text-bold text-light">
                    المالك
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody class="table-secondary">
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.Name)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Description)
                    </td>
                    <td>
                        <img src="@item.ImageUrl" class="img-thumbnail" style="width:64px; height:64px;" />
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Location)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Phone)
                    </td>
                    <td>
                        @item.User?.Name
                    </td>
                    <td>
                        <a class="btn btn-sm btn-warning" asp-action="Edit" asp-controller="Pharmacies" asp-route-id="@item.Id">Edit</a> |
                        <a class="btn btn-sm btn-info" asp-action="Details" asp-controller="Pharmacies" asp-route-id="@item.Id">Details</a> |
                        <a class="btn btn-sm btn-danger" asp-action="Delete" asp-controller="Pharmacies" asp-route-id="@item.Id">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>