<div id="pharmacies-section" class="pharmacies-section">
    <!-- العنوان مع التأثيرات -->
    <div class="section-header">
        <h2 class="animated-title">
            <span class="title-text">الصيدليات</span>
            <span class="title-shadow">الصيدليات</span>
        </h2>
        <div class="title-decoration">
            <span class="decoration-line"></span>
            <span class="decoration-icon"><i class="fas fa-prescription-bottle-alt"></i></span>
            <span class="decoration-line"></span>
        </div>
    </div>
    <!-- بطاقات الصيدليات -->



    <div class="container" style="margin-top: -35px;">
        <div class="row pharmacies-grid">

            @foreach (var item in Model)
            {
                <!-- البطاقة الأولى -->
                <a asp-action="Privacy" asp-controller="Home" asp-route-id="@item.Id" class=" col-md-3" style=" margin-top: 35px;">

                    <div class="pharmacy-card">
                        <div class="pharmacy-image">
                            <img src="@item.ImageUrl" alt="صيدلية صنعاء" />
                            @*<div class="rating-badge">
                                    <span class="star"><i class="fas fa-star"></i></span> 4.5
                                </div>*@
                        </div>
                        <div class="card-body">
                            <div class="pharmacy-name">@Html.DisplayFor(modelItem => item.Name)</div>
                            <div class="pharmacy-location">@Html.DisplayFor(modelItem => item.Location)</div>
                        </div>
                        <div class="card-footer">
                            <i class="fas fa-phone"></i>
                            <i class="fas fa-share-alt"></i>
                            <i class="fas fa-heart"></i>
                        </div>
                    </div>

                </a>
            }
        </div>
    </div>





</div>







