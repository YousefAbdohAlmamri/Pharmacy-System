@model Pharmacy_Web.ViewModels.CreateMedicineDto

@{
    ViewData["Title"] = "Create";
}



<div>
    <h1 class="text-secondary">إنشاء</h1>

    <h4 class="text-secondary">دواء</h4>
    <hr />
    <div class="row">
        <div class="col-md-12">
            <form method="post" asp-action="Create" enctype="multipart/form-data" >
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="form-group">
                    <label asp-for="Name" class="control-label text_label_input">الاسم</label>
                    <!--<input asp-for="Id" type="hidden" class="form-control input_data" />-->
                    <input asp-for="Name" name="Name" class="form-control input_data" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Description" class="control-label text_label_input">الوصف</label>
                    <input asp-for="Description" name="Description" class="form-control input_data" />
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="ImageFile" class="control-label text_label_input">الصورة</label>
                    <input type="file" name="ImageFile" asp-for="ImageFile" class="form-control input_data" onchange="loadFile(event)"  style="height: auto;"/>
                    <img id="myImg" class="img-thumbnail" style="width: 100px; height: 100px; background-color: unset; margin-top: 10px;"/>
                    <span asp-validation-for="ImageFile" class="text-danger"></span>
                </div>

                <div class="container mt-4">
                    <div class="row">
                        <div class="form-group col-md-6 mb-3">
                            <label asp-for="Company" class="control-label text_label_input">الشركة</label>
                            <input asp-for="Company" name="Company" class="form-control input_data" />
                            <span asp-validation-for="Company" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-6 mb-3">
                            <label asp-for="MadeIn" class="control-label text_label_input">بلاد الصنع</label>
                            <input asp-for="MadeIn" name="MadeIn" class="form-control input_data" />
                            <span asp-validation-for="MadeIn" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                
                
                <div class="container mt-4">
                    <div class="row">
                        <div class="form-group col-md-6 mb-3">
                            <label asp-for="Price" class="control-label text_label_input">السعر</label>
                            <input asp-for="Price" name="Price" class="form-control input_data" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-6 mb-3">
                            <label asp-for="DateCreated" class="control-label text_label_input">تاريخ الأنتاج</label>
                            <input asp-for="DateCreated" name="DateCreated" class="form-control input_data" />
                            <span asp-validation-for="DateCreated" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                
                <div class="container mt-4">
                    <div class="row">
                        <div class="form-group col-md-6 mb-3">
                            <label asp-for="ExpirationDate" class="control-label text_label_input">تاريخ الإنتهاء</label>
                            <input asp-for="ExpirationDate" name="ExpirationDate" class="form-control input_data" />
                            <span asp-validation-for="ExpirationDate" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-6 mb-3">
                            <label asp-for="CategoryId" class="control-label text_label_input">الفئة</label>
                            <select asp-for="CategoryId" name="CategoryId" class="form-control input_data" asp-items="ViewBag.CategoryId"></select>
                        </div>
                    </div>
                </div>

                <div class="form-group" style="margin-right: 10px;">
                    <input type="submit" value="إنشاء" class="btn btn-primary" /> |
                    <a class="btn btn-secondary" asp-action="Index">العودة للقائمة</a>
                </div>
            </form>
        </div>
    </div>


</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        var loadFile = function (event) {
            var reader = new FileReader();
            reader.onload = function () {
                var myImg = document.getElementById('myImg');
                myImg.src = reader.result;
            }
            reader.readAsDataURL(event.target.files[0]);
        }
    </script>
}
