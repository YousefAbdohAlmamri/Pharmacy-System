@model Pharmacy_Web.Models.User

@{
    ViewData["Title"] = "Edit";
}


<div >
    <h1 class="text-secondary">تعديل</h1>

    <h4 class="text-secondary">للمستخدم</h4>
    <hr />
    <div class="row" >
        <div class="col-md-12">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Id" />
                <div class="container mt-4">
                    <div class="row">
                        <div class="form-group col-md-6 mb-3">
                            <label asp-for="Name" class="control-label text_label_input">الاسم</label>
                            <input asp-for="Name" class="form-control input_data" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-6 mb-3">
                            <label asp-for="Password" class="control-label text_label_input">كلمة المرور</label>
                            <input asp-for="Password" class="form-control input_data" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="container mt-4">
                    <div class="row">
                        <div class="form-group col-md-6 mb-3">
                            <label asp-for="Phone" class="control-label text_label_input">التلفون</label>
                            <input asp-for="Phone" class="form-control input_data" />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-6 mb-3">
                            <label asp-for="Type" class="control-label text_label_input">الصلاحية</label>
                            <input asp-for="Type" class="form-control input_data" />
                            <span asp-validation-for="Type" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="form-group" style="margin-right: 10px;">
                    <input type="submit" value="حفظ" class="btn btn-primary" /> |
                    <a class="btn btn-secondary" asp-action="Index">العودة للقائمة</a>
                </div>
            </form>
        </div>
    </div>

</div>


@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
