@model Pharmacy_Web.Models.User

@{
    ViewData["Title"] = "Details";
}

<div >
    <h1 class="text-secondary">تفاصل</h1>

    <div>
        <h4 class="text-secondary">للمستخدم</h4>
        <hr />
        <dl class="row">
            <dt class="col-sm-2 for_key">
                الاسم
            </dt>
            <dd class="col-sm-10 for_value">
                @Html.DisplayFor(model => model.Name)
            </dd>
            <dt class="col-sm-2 for_key">
                كلمة المرور
            </dt>
            <dd class="col-sm-10 for_value">
                @Html.DisplayFor(model => model.Password)
            </dd>
            <dt class="col-sm-2 for_key">
                التلفون
            </dt>
            <dd class="col-sm-10 for_value">
                @Html.DisplayFor(model => model.Phone)
            </dd>
            <dt class="col-sm-2 for_key">
                الصلاحية
            </dt>
            <dd class="col-sm-10 for_value">
                @Html.DisplayFor(model => model.Type)
            </dd>
        </dl>
    </div>
    <div>
        <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@Model.Id">تعديل</a> |
        <a class="btn btn-secondary" asp-action="Index">العودة للقائمة</a>
    </div>

</div>