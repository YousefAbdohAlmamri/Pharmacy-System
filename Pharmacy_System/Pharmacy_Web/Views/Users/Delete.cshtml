@model Pharmacy_Web.Models.User

@{
    ViewData["Title"] = "Delete";
}

<div >
    <h1 class="text-secondary">حذف</h1>

    <h3 class="text-secondary">هل انت متأكد انك تريد حذف هذا الستخدم؟</h3>
    <div>
        @*<h4>User</h4>*@
        <hr />
        <dl class="row">
            <dt class="col-sm-2 for_key">
                الاسم
            </dt>
            <dd class="col-sm-10 for_value">
                @Html.DisplayFor(model => model.Name)
            </dd>
            <dt class="col-sm-2 for_key">
                كلمة المرور
            </dt>
            <dd class="col-sm-10 for_value">
                @Html.DisplayFor(model => model.Password)
            </dd>
            <dt class="col-sm-2 for_key">
                التلفون
            </dt>
            <dd class="col-sm-10 for_value">
                @Html.DisplayFor(model => model.Phone)
            </dd>
            <dt class="col-sm-2 for_key">
                الصلاحية
            </dt>
            <dd class="col-sm-10 for_value">
                @Html.DisplayFor(model => model.Type)
            </dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <input type="submit" value="حذف" class="btn btn-danger" /> |
            <a class="btn btn-secondary" asp-action="Index">العودة للقائمة</a>
        </form>
    </div>

</div>