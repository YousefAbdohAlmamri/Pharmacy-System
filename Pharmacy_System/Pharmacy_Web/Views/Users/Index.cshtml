@model IEnumerable<Pharmacy_Web.Models.User>

@{
    ViewData["Title"] = "Index";
}



<div >
    <h1 class="text-secondary">المستخدمين</h1>

    <p>
        <a asp-action="Create" class="btn btn-primary">إضافة مستخدم</a>
    </p>
    <table class="table table-striped table-hover table-bordered" style="border-color:#364556;">
        <thead class="table-dark">
            <tr>
                <th class="text-bold text-light">
                    الاسم
                </th>
                <th class="text-bold text-light">
                    كلمة المرور
                </th>
                <th class="text-bold text-light">
                    التلفون
                </th>
                <th class="text-bold text-light">
                    الصلاحية
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody class="table-secondary">
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.Name)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Password)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Phone)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Type)
                    </td>
                    <td>
                        <a class="btn btn-sm btn-warning" asp-action="Edit" asp-controller="Users" asp-route-id="@item.Id">Edit</a> |
                        <a class="btn btn-sm btn-info" asp-action="Details" asp-controller="Users" asp-route-id="@item.Id">Details</a> |
                        <a class="btn btn-sm btn-danger" asp-action="Delete" asp-controller="Users" asp-route-id="@item.Id">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>